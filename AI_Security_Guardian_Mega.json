      "id": "ca1ac292-3098-4fcc-9f6c-bbe0a8f2f30f",
      "name": "CODE_ExecutionSummary",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [
        50,
        4600
      ],
      "parameters": {
        "jsCode": "$json.execution_summary = {\n  assets_scanned: 1,\n  duration: 94,\n  findings: $json.vulnerabilities?.length || 0,\n  critical: $json.risk.score >= 90 ? 1 : 0,\n  high: $json.risk.score >= 70 && $json.risk.score < 90 ? 1 : 0,\n  medium: $json.risk.score >= 40 && $json.risk.score < 70 ? 1 : 0,\n  low: $json.risk.score >= 10 && $json.risk.score < 40 ? 1 : 0,\n  failed_scanners: []\n};\nreturn $json;\n"
      }
    },
    {
      "id": "ad65a2b8-0898-4375-8179-340d7457fa41",
      "name": "DB_InsertFindings",
      "type": "n8n-nodes-base.postgres",
