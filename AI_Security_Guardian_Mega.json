      "name": "CODE_AICostTracker",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [
        250,
        4100
      ],
      "parameters": {
        "jsCode": "// Mock token calculation or parse from OpenAI node if available\nconst tokens = JSON.stringify($json).length / 4;\n$json.ai_cost = {\n  model: \"gpt-4o\",\n  tokens: tokens,\n  estimated_cost: (tokens / 1000) * 0.01\n};\nreturn $json;\n"
