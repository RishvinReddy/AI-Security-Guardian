    {
      "id": "0ab98c51-3926-4410-943b-18824680f20f",
      "name": "CODE_CalculateRisk",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [
        50,
        3600
      ],
      "parameters": {
        "jsCode": "let score = 0;\n// Deterministic Logic: CVSS + EPSS + KEV + Ports + SSL + Headers + Exposure\nconst vulns = $json.vulnerabilities || [];\nif (vulns.length > 0) score += 40; // Example CVSS weight\nconst ports = $json.ports || [];\nif (ports.includes('3389') || ports.includes('22')) score += 15; // Risky open ports\nif ($json.ssl && $json.ssl.expired) score += 10;\nif (!$json.headers?.HSTS) score += 5;\n\n// Clamp score 0-100\n$json.risk.score = Math.min(Math.max(score, 0), 100);\nreturn $json;\n"
      }
    },
