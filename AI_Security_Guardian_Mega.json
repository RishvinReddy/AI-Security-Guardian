      "name": "SWITCH_Severity",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 1,
      "position": [
        450,
        4600
      ],
      "parameters": {
        "mode": "rules",
        "rules": {
          "rules": [
            {
              "conditions": {
                "number": [
                  {
                    "value1": "={{ $json.risk.score }}",
                    "operation": "largerEqual",
                    "value2": 90
